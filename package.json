{
  "name": "auracheck",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "echo \"E2E tests: no browser automation framework installed. Add Playwright for full E2E.\"",
    "test:e2e:ui": "playwright test --ui",
    "datasets:list": "node scripts/dataset-status.mjs",
    "datasets:status": "node scripts/dataset-status.mjs",
    "analyser:benchmark": "node scripts/analyser-benchmark.mjs",
    "analyser:safety": "node scripts/analyser-safety-check.mjs",
    "fixtures:generate": "node scripts/fixture-generate.mjs",
    "fixtures:verify": "node scripts/fixture-generate.mjs && echo Checking manifest... && test -f tests/fixtures/analyser/generated/manifest.json && echo ✅ || echo ❌",
    "fixtures:monotonicity": "node scripts/monotonicity-test.mjs",
    "test:quality-gate": "node scripts/quality-gate-regression.mjs",
    "fixtures:generate-images": "node scripts/generate-synthetic-images.mjs",
    "fixtures:benchmark": "node scripts/run-quality-gate-benchmark.mjs",
    "typecheck": "tsc --noEmit",
    "lint:new-errors": "npx eslint . --format compact 2>&1 | grep \"error\" | wc -l",
    "analyser:benchmark:gate": "node scripts/run-quality-gate-benchmark.mjs && node scripts/gate-check.mjs",
    "benchmarks:splits:generate": "node -e \"console.log(\"splits: placeholder — implement when real datasets available\")\"",
    "benchmarks:splits:verify": "node -e \"console.log(\"splits: no splits to verify\")\"",
    "benchmarks:splits:summary": "node -e \"console.log(\"splits: no splits assigned\")\"",
    "datasets:import-summary": "node -e \"console.log(\"import: 0 real images imported\")\"",
    "fixtures:summary": "node -e \"const m=JSON.parse(require(\"fs\").readFileSync(\"datasets/generated/summary.json\",\"utf-8\")); console.log(JSON.stringify(m,null,2))\"",
    "real-photos:import": "node scripts/import-real-photos.mjs",
    "real-photos:status": "node scripts/real-photo-readiness.mjs",
    "real-photos:validate": "echo \"No real photos to validate\"",
    "real-photos:index": "echo \"No real photos to index\"",
    "real-photos:summary": "node scripts/real-photo-readiness.mjs",
    "real-photos:discover": "node scripts/discover-commons.mjs",
    "real-photos:discover:commons": "node scripts/discover-commons.mjs",
    "real-photos:discover:openverse": "node scripts/discover-openverse.mjs",
    "real-photos:prefilter": "node scripts/prefilter-candidates.mjs",
    "real-photos:readiness": "node scripts/real-photo-readiness.mjs",
    "test:no-external-analysis": "node scripts/test-no-external-analysis.mjs",
    "test:security": "node scripts/test-no-external-analysis.mjs",
    "test:kill-switch": "node -e \"const f=require(\"./src/lib/feature-flags.ts\"); console.log(\"feature-flags module loads OK\")\""
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/supabase-js": "^2.110.2",
    "@tensorflow-models/body-segmentation": "^1.0.2",
    "@tensorflow-models/face-landmarks-detection": "^1.0.6",
    "@tensorflow/tfjs": "^4.22.0",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "next": "16.2.9",
    "posthog-js": "^1.399.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
