# AuraCheck — Environment Variables

# UPI ID for manual payment (required for unlock flow)
NEXT_PUBLIC_MANUAL_UPI_ID=your-upi-id@upi

# Owner WhatsApp number for payment notifications (optional)
# Include country code without + sign
NEXT_PUBLIC_OWNER_WHATSAPP=

# Support email (optional)
NEXT_PUBLIC_SUPPORT_EMAIL=

# Demo unlock code for testing
# Defaults to AURADEMO if not set
NEXT_PUBLIC_DEMO_UNLOCK_CODE=AURADEMO

# Local admin panel code (not production security)
# Defaults to ADMINDEMO if not set
NEXT_PUBLIC_LOCAL_ADMIN_CODE=ADMINDEMO
