# ============================================================
# AuraCheck / FixMyAura — Environment Variables
# ============================================================

## ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

## ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

## ─── Razorpay ───
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

## ─── Admin ───
ADMIN_ACCESS_CODE=
# Legacy (client-side visible, use ADMIN_ACCESS_CODE instead):
LOCAL_ADMIN_CODE=
NEXT_PUBLIC_LOCAL_ADMIN_CODE=ADMINDEMO

## ─── Support ───
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_OWNER_WHATSAPP=

## ─── Manual Payment Fallback ───
NEXT_PUBLIC_MANUAL_UPI_ID=
NEXT_PUBLIC_DEMO_UNLOCK_CODE=AURADEMO

## ─── Commerce ───
NEXT_PUBLIC_AFFILIATE_DISCLOSURE_ENABLED=true
COMMERCE_REFRESH_SECRET=
AFFILIATE_DEFAULT_COMMISSION_RATE=

## ─── Commerce Feed URLs (optional) ───
COMMERCE_GENERIC_CSV_FEED_URL=
COMMERCE_GENERIC_JSON_FEED_URL=
COMMERCE_GENERIC_FEED_TOKEN=

## ─── Affiliate Connectors (optional, placeholder) ───
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PAAPI_PARTNER_TAG=
AMAZON_PAAPI_HOST=webservices.amazon.com
AMAZON_PAAPI_REGION=us-east-1
FLIPKART_AFFILIATE_ID=
FLIPKART_AFFILIATE_TOKEN=
FLIPKART_FEED_URL=
CUELINKS_API_KEY=
CUELINKS_FEED_URL=
ADMITAD_CLIENT_ID=
ADMITAD_CLIENT_SECRET=
ADMITAD_ACCESS_TOKEN=
ADMITAD_FEED_URL=
