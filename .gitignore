# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# python (skill scripts)
__pycache__/
*.pyc

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ponytail: dataset exclusions — raw images and model weights never in Git
datasets/raw/
datasets/cache/
datasets/private/
datasets/generated/
datasets/*.tar.gz
datasets/*.zip
datasets/*.7z
models/
*.onnx
*.pb
*.pt
*.pth
*.weights
artifacts/benchmarks/*.json
artifacts/benchmarks/*.md
datasets/real-photos/quarantined/
datasets/real-photos/acquisition-cache/
