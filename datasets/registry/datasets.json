{
  "version": "1.0.0",
  "datasets": [
    {
      "id": "spaqp",
      "name": "SPAQ — Smartphone Photography Attribute and Quality",
      "purpose": ["smartphone-quality"],
      "officialSource": "https://github.com/hellowangqian/SPAQ",
      "licenceSource": "https://github.com/hellowangqian/SPAQ/blob/main/LICENSE",
      "licenceStatus": "research-only",
      "commercialTrainingAllowed": null,
      "commercialEvaluationAllowed": true,
      "redistributionAllowed": false,
      "attributionRequired": true,
      "manualAcceptanceRequired": true,
      "downloadMethod": "manual",
      "expectedAnnotationTypes": ["mos", "device", "scene"],
      "notes": ["Requires manual download from official repo. Research licence — commercial training requires separate approval."]
    },
    {
      "id": "koniq-10k",
      "name": "KonIQ-10k — IQA Database",
      "purpose": ["image-quality"],
      "officialSource": "http://database.mmsp-kn.de/koniq-10k-database.html",
      "paperSource": "https://arxiv.org/abs/1907.11159",
      "licenceSource": "http://database.mmsp-kn.de/koniq-10k-database.html",
      "licenceStatus": "research-only",
      "commercialTrainingAllowed": null,
      "commercialEvaluationAllowed": true,
      "redistributionAllowed": false,
      "attributionRequired": true,
      "manualAcceptanceRequired": true,
      "downloadMethod": "manual",
      "expectedAnnotationTypes": ["mos", "distribution"],
      "notes": ["Download from official source. Research use. 10,125 images with MOS scores."]
    },
    {
      "id": "live-in-the-wild",
      "name": "LIVE In the Wild Image Quality Challenge Database",
      "purpose": ["image-quality"],
      "officialSource": "https://live.ece.utexas.edu/research/Quality/",
      "paperSource": "https://ieeexplore.ieee.org/document/7120097",
      "licenceStatus": "research-only",
      "commercialTrainingAllowed": null,
      "commercialEvaluationAllowed": true,
      "redistributionAllowed": false,
      "attributionRequired": true,
      "manualAcceptanceRequired": true,
      "downloadMethod": "manual",
      "expectedAnnotationTypes": ["mos"],
      "notes": ["Requires registration at official source. 1,162 images with MOS scores from 20+ mobile devices."]
    },
    {
      "id": "wider-face",
      "name": "WIDER FACE — Face Detection Dataset",
      "purpose": ["face-detection"],
      "officialSource": "http://shuoyang1213.me/WIDERFACE/",
      "licenceSource": "http://shuoyang1213.me/WIDERFACE/",
      "licenceStatus": "research-only",
      "commercialTrainingAllowed": null,
      "commercialEvaluationAllowed": true,
      "redistributionAllowed": false,
      "attributionRequired": true,
      "manualAcceptanceRequired": true,
      "downloadMethod": "manual",
      "expectedAnnotationTypes": ["face-bbox", "face-count", "occlusion", "pose"],
      "notes": ["32,203 images with 193,939 faces. Three splits: Easy/Medium/Hard. Requires manual download."]
    },
    {
      "id": "synthetic-fixtures",
      "name": "Synthetic Distortion Fixtures",
      "purpose": ["screenshot-detection", "custom-validation"],
      "officialSource": "local",
      "licenceStatus": "approved",
      "commercialTrainingAllowed": true,
      "commercialEvaluationAllowed": true,
      "redistributionAllowed": true,
      "attributionRequired": false,
      "manualAcceptanceRequired": false,
      "downloadMethod": "automatic",
      "expectedAnnotationTypes": ["transformation-type", "expected-quality-gate"],
      "notes": ["Generated locally from approved source images via syntheticTransformations.ts"]
    }
  ]
}
